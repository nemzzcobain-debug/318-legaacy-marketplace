# ══════════════════════════════════════════════════
# 318 LEGAACY Marketplace - Variables d'environnement
# ══════════════════════════════════════════════════

# ─── Base de donnees (Supabase PostgreSQL) ───
# supabase.com > Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# ─── NextAuth ───
NEXTAUTH_URL="https://ton-domaine.com"
NEXTAUTH_SECRET="openssl rand -base64 32"

# ─── Stripe ───
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
PLATFORM_COMMISSION_PERCENT=15

# ─── Cron Secret ───
CRON_SECRET="genere-un-secret-unique"

# ─── PayPal (optionnel) ───
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""

# ─── Supabase (Storage pour fichiers audio/images & Realtime) ───
NEXT_PUBLIC_SUPABASE_URL="https://onfwowxfflnijuvpspkq.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Upload ───
UPLOAD_MAX_SIZE_MB=50

# ─── Resend (emails transactionnels) ───
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@318marketplace.com"

# ─── App URL ───
NEXT_PUBLIC_APP_URL="https://www.318marketplace.com"

# ─── Email SMTP (fallback, optionnel) ───
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
