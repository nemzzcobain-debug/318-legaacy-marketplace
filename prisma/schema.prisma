// ─── 318 LEGAACY Marketplace - Database Schema ───
// Premiere plateforme d'encheres de beats en France
// Production: PostgreSQL (Supabase) | Dev: SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USERS & AUTH ───
// role: ARTIST | PRODUCER | ADMIN
// producerStatus: PENDING | APPROVED | REJECTED | SUSPENDED

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  passwordHash   String
  name           String
  displayName    String?
  avatar         String?
  bio            String?
  role           String    @default("ARTIST")

  // Producer specific
  producerStatus String?
  producerBio    String?
  portfolio      String?
  stripeAccountId String?

  // Stats
  totalSales     Int       @default(0)
  totalPurchases Int       @default(0)
  rating         Float     @default(0)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  beats          Beat[]
  bids           Bid[]
  wonAuctions    Auction[] @relation("AuctionWinner")
  notifications  Notification[]
  likes          Like[]
  accounts       Account[]
  sessions       Session[]

  // Follows
  followers             Follow[] @relation("Following")
  following             Follow[] @relation("Followers")

  // Reviews
  reviewsGiven          Review[] @relation("ReviewAuthor")
  reviewsReceived       Review[] @relation("ReviewProducer")

  // Chat
  conversationsAsUser1  Conversation[] @relation("ConvUser1")
  conversationsAsUser2  Conversation[] @relation("ConvUser2")
  sentMessages          Message[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── BEATS ───
// status: DRAFT | PENDING | ACTIVE | SOLD | ARCHIVED

model Beat {
  id          String   @id @default(cuid())
  title       String
  description String?

  // Audio
  audioUrl    String
  audioWav    String?
  stemsUrl    String?
  duration    Int?
  waveform    String?

  // Metadata
  genre       String
  mood        String?
  bpm         Int
  key         String?
  tags        String   @default("") // JSON string array

  // Cover art
  coverImage  String?

  // Status
  status      String   @default("DRAFT")
  plays       Int      @default(0)

  // Producer
  producerId  String
  producer    User     @relation(fields: [producerId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  auctions    Auction[]
  likes       Like[]
}

// ─── AUCTIONS (ENCHERES) ───
// status: SCHEDULED | ACTIVE | ENDING_SOON | ENDED | COMPLETED | CANCELLED
// licenseType: BASIC | PREMIUM | EXCLUSIVE

model Auction {
  id             String   @id @default(cuid())

  beatId         String
  beat           Beat     @relation(fields: [beatId], references: [id])

  // Prix
  startPrice     Float
  currentBid     Float
  reservePrice   Float?
  buyNowPrice    Float?
  bidIncrement   Float    @default(5)

  // Licence
  licenseType    String   @default("BASIC")

  // Multiplicateurs
  premiumMultiplier  Float @default(2.5)
  exclusiveMultiplier Float @default(10)

  // Timing
  startTime      DateTime
  endTime        DateTime

  // Anti-snipe
  antiSnipeMinutes Int    @default(2)
  antiSnipeExtension Int  @default(2)

  // Status
  status         String   @default("SCHEDULED")
  totalBids      Int      @default(0)

  // Winner
  winnerId       String?
  winner         User?    @relation("AuctionWinner", fields: [winnerId], references: [id])
  winningLicense String?
  finalPrice     Float?

  // Commission
  commissionPercent Float @default(15)
  commissionAmount  Float?
  producerPayout    Float?

  // Payment
  stripePaymentId   String?
  paypalPaymentId   String?
  paidAt            DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  bids           Bid[]
  review         Review?
}

// ─── BIDS ───

model Bid {
  id          String   @id @default(cuid())

  amount      Float
  licenseType String   @default("BASIC")
  finalAmount Float

  isAutoBid   Boolean  @default(false)
  maxAutoBid  Float?

  auctionId   String
  auction     Auction  @relation(fields: [auctionId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())
}

// ─── LIKES ───

model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  beatId    String
  beat      Beat     @relation(fields: [beatId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, beatId])
}

// ─── REVIEWS ───

model Review {
  id          String   @id @default(cuid())
  rating      Int      // 1-5
  comment     String?

  // Author (buyer who won an auction)
  authorId    String
  author      User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  // Producer being reviewed
  producerId  String
  producer    User     @relation("ReviewProducer", fields: [producerId], references: [id], onDelete: Cascade)

  // Linked auction (proof of purchase)
  auctionId   String   @unique
  auction     Auction  @relation(fields: [auctionId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([authorId, auctionId])
}

// ─── FOLLOWS ───

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

// ─── NOTIFICATIONS ───
// type: BID_PLACED | OUTBID | AUCTION_WON | AUCTION_ENDING | AUCTION_ENDED | PAYMENT_RECEIVED | PRODUCER_APPROVED | PRODUCER_REJECTED | SYSTEM

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ─── CONVERSATIONS ───

model Conversation {
  id            String   @id @default(cuid())

  user1Id       String
  user1         User     @relation("ConvUser1", fields: [user1Id], references: [id])
  user2Id       String
  user2         User     @relation("ConvUser2", fields: [user2Id], references: [id])

  lastMessage   String?
  lastMessageAt DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages      Message[]

  @@unique([user1Id, user2Id])
}

// ─── MESSAGES ───

model Message {
  id             String   @id @default(cuid())

  content        String
  read           Boolean  @default(false)

  senderId       String
  sender         User     @relation(fields: [senderId], references: [id])

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
}
