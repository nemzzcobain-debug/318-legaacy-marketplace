// ─── 318 LEGAACY Marketplace - Database Schema ───
// Premiere plateforme d'encheres de beats en France
// Production: PostgreSQL (Supabase) | Dev: SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USERS & AUTH ───
// role: ARTIST | PRODUCER | ADMIN
// producerStatus: PENDING | APPROVED | REJECTED | SUSPENDED

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  passwordHash   String?
  name           String
  displayName    String?
  avatar         String?
  image          String?
  bio            String?
  role           String    @default("ARTIST")

  // Social links
  website        String?
  instagram      String?
  twitter        String?
  youtube        String?
  soundcloud     String?
  spotify        String?

  // Preferences
  notifEmail     Boolean   @default(true)
  notifBid       Boolean   @default(true)
  notifMessage   Boolean   @default(true)

  // Account deletion (soft delete)
  deletedAt        DateTime?
  unsubscribeToken String?   @unique

  // Producer specific
  producerStatus String?
  producerBio    String?
  portfolio      String?
  stripeAccountId String?

  // Two-Factor Authentication
  twoFactorEnabled  Boolean  @default(false)
  twoFactorSecret   String?

  // Stats
  totalSales     Int       @default(0)
  totalPurchases Int       @default(0)
  rating         Float     @default(0)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  beats          Beat[]
  bids           Bid[]
  wonAuctions    Auction[] @relation("AuctionWinner")
  notifications  Notification[]
  likes          Like[]
  accounts       Account[]
  sessions       Session[]

  // Follows
  followers             Follow[] @relation("Following")
  following             Follow[] @relation("Followers")

  // Reviews
  reviewsGiven          Review[] @relation("ReviewAuthor")
  reviewsReceived       Review[] @relation("ReviewProducer")

  // Chat
  conversationsAsUser1  Conversation[] @relation("ConvUser1")
  conversationsAsUser2  Conversation[] @relation("ConvUser2")
  sentMessages          Message[]

  // Reports
  reportsGiven          Report[] @relation("ReportsGiven")

  // Watchlist
  watchlist             Watchlist[]

  // Playlists
  playlists             Playlist[]

  // Achats directs
  purchases             Purchase[]

  @@index([role])
  @@index([producerStatus])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

// ─── BEATS ───
// status: DRAFT | PENDING | ACTIVE | SOLD | ARCHIVED

model Beat {
  id          String   @id @default(cuid())
  title       String
  description String?

  // Audio
  audioUrl    String
  audioWav    String?
  stemsUrl    String?
  duration    Int?
  waveform    String?

  // Metadata
  genre       String
  mood        String?
  bpm         Int
  key         String?
  tags        String   @default("") // JSON string array

  // Cover art
  coverImage  String?

  // Status
  status      String   @default("DRAFT")
  plays       Int      @default(0)

  // Featured (admin selection)
  isFeatured    Boolean  @default(false)
  featuredOrder Int      @default(0)
  featuredAt    DateTime?

  // Producer
  producerId  String
  producer    User     @relation(fields: [producerId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  auctions    Auction[]
  likes       Like[]
  playlists   PlaylistBeat[]
  purchases   Purchase[]

  @@index([producerId])
  @@index([status])
  @@index([genre])
}

// ─── AUCTIONS (ENCHERES) ───
// status: SCHEDULED | ACTIVE | ENDING_SOON | ENDED | COMPLETED | CANCELLED
// licenseType: BASIC | PREMIUM | EXCLUSIVE

model Auction {
  id             String   @id @default(cuid())

  beatId         String
  beat           Beat     @relation(fields: [beatId], references: [id])

  // Prix
  startPrice     Float
  currentBid     Float
  reservePrice   Float?
  buyNowPrice    Float?
  bidIncrement   Float    @default(5)

  // Licence
  licenseType    String   @default("BASIC")

  // Multiplicateurs
  premiumMultiplier  Float @default(2.5)
  exclusiveMultiplier Float @default(10)

  // Timing
  startTime      DateTime
  endTime        DateTime

  // Anti-snipe
  antiSnipeMinutes Int    @default(2)
  antiSnipeExtension Int  @default(2)

  // Status
  status         String   @default("SCHEDULED")
  totalBids      Int      @default(0)

  // Winner
  winnerId       String?
  winner         User?    @relation("AuctionWinner", fields: [winnerId], references: [id])
  winningLicense String?
  finalPrice     Float?

  // Commission
  commissionPercent Float @default(15)
  commissionAmount  Float?
  producerPayout    Float?

  // Payment
  stripePaymentId   String?
  paypalPaymentId   String?
  paidAt            DateTime?
  paymentDeadline   DateTime?  // Deadline pour le gagnant (48h apres finalisation)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  bids           Bid[]
  review         Review?
  watchlist      Watchlist[]

  @@index([beatId])
  @@index([status, endTime])
  @@index([winnerId])
  @@index([status])
}

// ─── BIDS ───

model Bid {
  id          String   @id @default(cuid())

  amount      Float
  licenseType String   @default("BASIC")
  finalAmount Float

  isAutoBid   Boolean  @default(false)
  maxAutoBid  Float?

  auctionId   String
  auction     Auction  @relation(fields: [auctionId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())

  @@index([auctionId])
  @@index([userId])
  @@index([auctionId, createdAt])
}

// ─── LIKES ───

model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  beatId    String
  beat      Beat     @relation(fields: [beatId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, beatId])
  // SECURITY FIX M8: Index individuels pour les requetes par beatId ou userId seul
  @@index([beatId])
  @@index([userId])
}

// ─── REVIEWS ───

model Review {
  id          String   @id @default(cuid())
  rating      Int      // 1-5
  comment     String?

  // Author (buyer who won an auction)
  // SECURITY FIX M5: SetNull au lieu de Cascade pour preserver l'historique des reviews
  authorId    String?
  author      User?    @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  // Producer being reviewed
  producerId  String?
  producer    User?    @relation("ReviewProducer", fields: [producerId], references: [id], onDelete: SetNull)

  // Linked auction (proof of purchase)
  auctionId   String   @unique
  auction     Auction  @relation(fields: [auctionId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([authorId, auctionId])
  @@index([producerId])
  @@index([authorId])
}

// ─── FOLLOWS ───

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

// ─── NOTIFICATIONS ───
// type: BID_PLACED | OUTBID | AUCTION_WON | AUCTION_ENDING | AUCTION_ENDED | PAYMENT_RECEIVED | PRODUCER_APPROVED | PRODUCER_REJECTED | SYSTEM

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
}

// ─── CONVERSATIONS ───

model Conversation {
  id            String   @id @default(cuid())

  user1Id       String
  user1         User     @relation("ConvUser1", fields: [user1Id], references: [id])
  user2Id       String
  user2         User     @relation("ConvUser2", fields: [user2Id], references: [id])

  lastMessage   String?
  lastMessageAt DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages      Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@index([lastMessageAt])
}

// ─── MESSAGES ───

model Message {
  id             String   @id @default(cuid())

  content        String
  read           Boolean  @default(false)

  senderId       String
  sender         User     @relation(fields: [senderId], references: [id])

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ─── REPORTS (SIGNALEMENTS) ───
// type: BEAT | AUCTION | USER | MESSAGE
// status: PENDING | REVIEWED | RESOLVED | DISMISSED

model Report {
  id          String   @id @default(cuid())
  type        String   // BEAT, AUCTION, USER, MESSAGE
  reason      String   // SPAM, INAPPROPRIATE, FRAUD, COPYRIGHT, OTHER
  description String?
  status      String   @default("PENDING")

  // Reporter
  reporterId  String
  reporter    User     @relation("ReportsGiven", fields: [reporterId], references: [id], onDelete: Cascade)

  // Target (one of these will be set)
  targetUserId    String?
  targetAuctionId String?
  targetBeatId    String?

  // Admin response
  adminNote   String?
  reviewedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([reporterId])
  @@index([status])
  // SECURITY FIX L5: Index sur les cibles pour les requetes admin
  @@index([targetUserId])
  @@index([targetAuctionId])
  @@index([targetBeatId])
}

// ─── WATCHLIST (FAVORIS ENCHERES) ───

model Watchlist {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, auctionId])
}

// ─── CODES PROMO ───
// type: PERCENTAGE | FIXED
// status: ACTIVE | EXPIRED | DISABLED

model PromoCode {
  id             String   @id @default(cuid())
  code           String   @unique
  type           String   @default("PERCENTAGE") // PERCENTAGE ou FIXED
  value          Float    // ex: 15 pour 15% ou 10 pour 10 EUR
  minPrice       Float?   // prix minimum pour appliquer
  maxUses        Int?     // nombre max d'utilisations (null = illimite)
  currentUses    Int      @default(0)
  expiresAt      DateTime?
  status         String   @default("ACTIVE")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Utilisations
  usages         PromoUsage[]
}

model PromoUsage {
  id          String   @id @default(cuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  userId      String
  auctionId   String
  discount    Float    // montant de la reduction appliquee
  createdAt   DateTime @default(now())

  @@unique([promoCodeId, userId, auctionId])
}

// ─── PLAYLISTS / COLLECTIONS ───
// visibility: PUBLIC | PRIVATE

model Playlist {
  id          String   @id @default(cuid())
  name        String
  description String?
  coverImage  String?
  visibility  String   @default("PUBLIC") // PUBLIC ou PRIVATE

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  beats       PlaylistBeat[]

  @@index([userId])
  @@index([visibility])
}

model PlaylistBeat {
  id         String   @id @default(cuid())
  position   Int      @default(0)

  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  beatId     String
  beat       Beat     @relation(fields: [beatId], references: [id], onDelete: Cascade)

  addedAt    DateTime @default(now())

  @@unique([playlistId, beatId])
}

// ─── PURCHASES (ACHATS DIRECTS) ───
// type: DIRECT | AUCTION
// status: PENDING | COMPLETED | REFUNDED

model Purchase {
  id             String   @id @default(cuid())

  // Acheteur
  buyerId        String
  buyer          User     @relation(fields: [buyerId], references: [id])

  // Beat achete
  beatId         String
  beat           Beat     @relation(fields: [beatId], references: [id])

  // Type d'achat
  type           String   @default("DIRECT") // DIRECT ou AUCTION
  licenseType    String   // BASIC, PREMIUM, EXCLUSIVE

  // Prix
  amount         Float    // Prix paye
  commission     Float    // Commission plateforme
  producerPayout Float    // Part du producteur

  // Stripe
  stripePaymentId String?
  status          String  @default("PENDING") // PENDING, COMPLETED, REFUNDED

  // Lien optionnel vers l'enchere (si achat via enchère)
  auctionId      String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([buyerId])
  @@index([beatId])
  @@index([status])
  @@index([stripePaymentId])
}

// ─── STRIPE EVENTS (IDEMPOTENCE WEBHOOK) ───
// Remplace le Set en memoire qui se reset a chaque cold start

model StripeEvent {
  id          String   @id // = Stripe event ID (evt_xxx)
  type        String   // ex: payment_intent.succeeded
  processedAt DateTime @default(now())

  @@index([processedAt])
}
